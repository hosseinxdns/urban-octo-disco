export default {
  async fetch(req) {
    try {
      const url = new URL(req.url);
      url.hostname = 's9.serv00.com';
      url.port = '3008';
      url.protocol = 'http';
      url.pathname = '/';
      const newReq = new Request(url, req);
      return fetch(newReq);

    } catch (e) {
      return new Response(e.message, { status: 500 });
    }
  }
};
